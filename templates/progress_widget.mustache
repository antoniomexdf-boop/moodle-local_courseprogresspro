{{!
    @template local_courseprogresspro/progress_widget

    Course progress widget and pending timeline.

    Context variables required for this template:
    * label string
    * value int
    * percentage string
    * maxlabel string
    * showpercentage bool
    * showpendingbutton bool
    * pendingbuttonlabel string
    * pendingtitle string
    * closemodal string
    * pendingempty string
    * pendingitems array

    Example context (json):
    {
        "label": "Your course progress",
        "value": 65,
        "percentage": "65%",
        "maxlabel": "100%",
        "showpercentage": true,
        "showpendingbutton": true,
        "pendingbuttonlabel": "What remains: 5 pending actions",
        "pendingtitle": "Pending activities",
        "closemodal": "Close window",
        "pendingempty": "There are no pending activities.",
        "pendingitems": []
    }
}}
<div class="local-courseprogresspro__title">{{label}}</div>
<div class="local-courseprogresspro__track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="{{value}}">
    <span class="local-courseprogresspro__fill" style="width: {{value}}%;"></span>
</div>
<div class="local-courseprogresspro__meta">
    <div class="local-courseprogresspro__value">
        {{#showpercentage}}{{percentage}}{{/showpercentage}}
    </div>
    <div class="local-courseprogresspro__max">{{maxlabel}}</div>
</div>
<div class="local-courseprogresspro__actions">
    {{#showpendingbutton}}
        <button type="button" class="local-courseprogresspro__button" data-action="open-pending">{{pendingbuttonlabel}}</button>
    {{/showpendingbutton}}
</div>
<div class="local-courseprogresspro__modal" hidden="hidden" role="dialog" aria-modal="true">
    <button type="button" class="local-courseprogresspro__backdrop" data-action="close-pending" aria-label="{{closemodal}}"></button>
    <div class="local-courseprogresspro__modal-card">
        <div class="local-courseprogresspro__modal-header">
            <div class="local-courseprogresspro__modal-title">{{pendingtitle}}</div>
            <button type="button" class="local-courseprogresspro__close" data-action="close-pending" aria-label="{{closemodal}}">&times;</button>
        </div>
        {{#haspendingitems}}
            <ul class="local-courseprogresspro__pending-list">
                {{#pendingitems}}
                    <li class="local-courseprogresspro__pending-item local-courseprogresspro__pending-item--timeline {{statusclass}}">
                        <span class="local-courseprogresspro__dot" aria-hidden="true"></span>
                        <div class="local-courseprogresspro__pending-content">
                            <div class="local-courseprogresspro__pending-top">
                                <span class="local-courseprogresspro__pending-name">{{name}}</span>
                                <span class="local-courseprogresspro__pending-type local-courseprogresspro__pending-type--{{modname}}">{{type}}</span>
                            </div>
                            <div class="local-courseprogresspro__pending-detail">{{detail}}</div>
                            {{#availabilityinfo}}
                                <div class="local-courseprogresspro__pending-availability">{{availabilityinfo}}</div>
                            {{/availabilityinfo}}
                            <div class="local-courseprogresspro__pending-meta">
                                <span class="local-courseprogresspro__pending-status {{statusclass}}">{{status}}</span>
                                {{#hasurl}}
                                    <a class="local-courseprogresspro__pending-link" href="{{url}}">{{linklabel}}</a>
                                {{/hasurl}}
                            </div>
                        </div>
                    </li>
                {{/pendingitems}}
            </ul>
        {{/haspendingitems}}
        {{^haspendingitems}}
            <p class="local-courseprogresspro__empty">{{pendingempty}}</p>
        {{/haspendingitems}}
    </div>
</div>
